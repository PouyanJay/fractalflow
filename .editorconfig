# EditorConfig — consistent coding styles across editors (https://editorconfig.org)
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = tab
insert_final_newline = true
trim_trailing_whitespace = true

# YAML requires spaces.
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Preserve hard line breaks in Markdown.
[*.md]
trim_trailing_whitespace = false
